# PostgreSQL
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=notifier_db

# n8n
N8N_ENCRYPTION_KEY=replace_with_32_char_random_string
N8N_USER=your_n8n_email@example.com
N8N_PASSWORD=your_n8n_password
N8N_PORT=5679

# Evolution API
EVO_PORT=9001
WA_API_TOKEN=replace_with_your_api_token

# Gemini API key(s)
# If you use multiple keys, separate them with commas.
GEMINI_API_KEY=your_gemini_api_key
