    {
      "parameters": {
        "jsCode": "const events = $input.all();\nlet message = \"\";\n\nconst now = new Date();\n\nif (events.length === 0) {\n  message = \"Kosong melompong bro! Nggak ada jadwal masuk buat hari ini. Bisa santai dulu atau lanjutin project Titipin! ☕\";\n} else {\n\n  const getStart = (event) => {\n    if (event.json.start?.dateTime) {\n      return new Date(event.json.start.dateTime).getTime();\n    }\n    return Infinity;\n  };\n\n  events.sort((a, b) => (getStart(a) - now.getTime()) - (getStart(b) - now.getTime()));\n\n  message = \"🗓️ *RECAP JADWAL HARI INI*\\n\\n\";\n\n  let nextAssigned = false;\n\n  events.forEach((event, index) => {\n    let startTime = \"-\";\n    let label = \"\";\n\n    if (event.json.start?.dateTime) {\n      const start = new Date(event.json.start.dateTime);\n      const end = event.json.end?.dateTime\n        ? new Date(event.json.end.dateTime)\n        : new Date(start.getTime() + 60 * 60 * 1000);\n\n      const diffMs = start - now;\n      const diffMinutes = Math.floor(diffMs / 60000);\n\n      if (now >= start && now <= end) {\n        label = \" 🔥 *NOW*\";\n      } \n      else if (now > end) {\n        label = \" ✅ *DONE*\";\n      } \n      else if (diffMs > 0 && !nextAssigned) {\n        label = \" 🚀 *NEXT*\";\n        nextAssigned = true;\n\n        if (diffMinutes <= 60) {\n          label += ` ⏳ (${diffMinutes} menit lagi)`;\n        }\n      } \n      else if (diffMs > 0 && diffMinutes <= 60) {\n        label = ` ⏳ (${diffMinutes} menit lagi)`;\n      }\n\n      startTime = start.toLocaleTimeString('id-ID', {\n        hour: '2-digit',\n        minute: '2-digit',\n        timeZone: 'Asia/Jakarta'\n      });\n\n    } else if (event.json.start?.date) {\n      startTime = \"Seharian\";\n    }\n    \nlet title = `*${event.json.summary}*`;\n\nif (label.includes(\"DONE\")) {\n  title = `~*${event.json.summary}*~`;\n}\n\nmessage += `${index + 1}. ${title}${label}\\n⏰ ${startTime} WIB\\n\\n`;\n  });\n\n  message += \"Gas terus bro, lu udah on track hari ini 💪🔥\";\n}\n\nreturn { message };"
      },
