    {
      "parameters": {
        "jsCode": "const apiKeys = [\n  \"{{GEMINI_API_KEY_PLACEHOLDER}}\",\n  \"{{GEMINI_API_KEY_PLACEHOLDER}}\",\n  \"{{GEMINI_API_KEY_PLACEHOLDER}}\",\n  \"{{GEMINI_API_KEY_PLACEHOLDER}}\",\n  \"{{GEMINI_API_KEY_PLACEHOLDER}}\"\n];\n\nconst validItems = [];\nconst processedIds = new Set();\nconst now = new Date();\n\nfor (const item of $input.all()) {\n  const startStr = item.json.start?.dateTime;\n  if (!startStr) continue;\n\n  const eventId = item.json.id;\n  \n\n  if (processedIds.has(eventId)) continue;\n\n  const startTime = new Date(startStr);\n  const diffMs = startTime.getTime() - now.getTime();\n  const diffMinutes = Math.round(diffMs / 60000);\n\n  const targetMinutes = [15];\n\n  const isTargetTime = targetMinutes.some(target => \n    diffMinutes >= target && diffMinutes <= target\n  );\n\n  if (isTargetTime) {\n    processedIds.add(eventId);\n    item.json.selected_key = apiKeys[Math.floor(Math.random() * apiKeys.length)];\n    item.json.menit_tersisa = diffMinutes;\n    validItems.push(item);\n  }\n}\n\nreturn validItems;"
